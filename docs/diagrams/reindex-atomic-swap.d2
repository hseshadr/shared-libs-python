# Background Reindex + Atomic Swap Pattern
# Shows the shadow index build and atomic swap process

direction: right

classes: {
  active: {
    shape: cylinder
    style.fill: "#4caf50"
    style.font-color: "#ffffff"
    style.stroke-width: 3
    style.stroke: "#2e7d32"
  }
  shadow: {
    shape: cylinder
    style.fill: "#ff9800"
    style.font-color: "#ffffff"
    style.stroke-width: 2
    style.stroke: "#ef6c00"
  }
  new_active: {
    shape: cylinder
    style.fill: "#4caf50"
    style.font-color: "#ffffff"
    style.stroke-width: 3
    style.stroke: "#2e7d32"
  }
  retired: {
    shape: cylinder
    style.fill: "#9e9e9e"
    style.font-color: "#ffffff"
    style.stroke-dash: 3
  }
  process: {
    shape: rectangle
    style.fill: "#438dd5"
    style.font-color: "#ffffff"
    style.border-radius: 4
  }
  phase: {
    shape: rectangle
    style.fill: "#1565c0"
    style.font-color: "#ffffff"
    style.border-radius: 8
    style.bold: true
  }
  arrow_box: {
    shape: rectangle
    style.fill: "#e3f2fd"
    style.stroke: "#1976d2"
    style.border-radius: 4
  }
  check: {
    shape: hexagon
    style.fill: "#e8f5e9"
    style.stroke: "#43a047"
  }
  cleanup: {
    shape: rectangle
    style.fill: "#ffebee"
    style.stroke: "#ef5350"
    style.border-radius: 4
  }
  queries: {
    shape: rectangle
    style.fill: "#fff9c4"
    style.stroke: "#f9a825"
    style.border-radius: 4
  }
  writes: {
    shape: rectangle
    style.fill: "#f3e5f5"
    style.stroke: "#8e24aa"
    style.border-radius: 4
  }
}

title: "Background Reindex + Atomic Swap Pattern" {
  style.font-size: 24
  style.bold: true
  style.font-color: "#1565c0"
  near: top-center
}

# ============================================
# PHASE 1: Start Build B
# ============================================

phase1: Phase 1 - Start Build B {
  style.fill: "#e8f5e9"
  style.stroke: "#4caf50"

  p1_title: "Start Shadow Build" {class: phase}

  idx_a1: "Index A\n(ACTIVE)" {class: active}
  idx_b1: "Index B\n(BUILDING)" {class: shadow}

  snapshot: "Build from\nSnapshot" {class: process}

  queries1: "All Queries" {class: queries}

  queries1 -> idx_a1: "Serving"
  snapshot -> idx_b1: "Building"

  note1: "Create new index from snapshot of all live vectors" {
    style.font-size: 10
    style.fill: "#ffffff"
  }
}

# ============================================
# PHASE 2: Dual-Write Period
# ============================================

phase2: Phase 2 - Dual-Write Period {
  style.fill: "#fff3e0"
  style.stroke: "#ff9800"

  p2_title: "Dual-Write Active" {class: phase}

  idx_a2: "Index A\n(ACTIVE)" {class: active}
  idx_b2: "Index B\n(BUILDING)" {class: shadow}

  writes2: "Inserts/Updates/Deletes" {class: writes}
  queries2: "All Queries" {class: queries}

  queries2 -> idx_a2: "Serving"
  writes2 -> idx_a2: "Write"
  writes2 -> idx_b2: "Write"

  note2: "All writes go to BOTH indices" {
    style.font-size: 10
    style.fill: "#ffffff"
  }
}

# ============================================
# PHASE 3: Delta Sync
# ============================================

phase3: Phase 3 - Delta Sync {
  style.fill: "#e3f2fd"
  style.stroke: "#1976d2"

  p3_title: "Catch Up Events" {class: phase}

  idx_a3: "Index A\n(ACTIVE)" {class: active}
  idx_b3: "Index B\n(READY)" {class: shadow}

  delta: "Sync events\nsince build start" {class: process}

  queries3: "All Queries" {class: queries}

  queries3 -> idx_a3: "Serving"
  delta -> idx_b3: "Until lag = 0"

  note3: "Continue until B is fully caught up" {
    style.font-size: 10
    style.fill: "#ffffff"
  }
}

# ============================================
# PHASE 4: Validation
# ============================================

phase4: Phase 4 - Validation {
  style.fill: "#f3e5f5"
  style.stroke: "#8e24aa"

  p4_title: "Validate Before Swap" {class: phase}

  idx_a4: "Index A\n(ACTIVE)" {class: active}
  idx_b4: "Index B\n(VALIDATED)" {class: shadow}

  checks: Validation Checks {
    style.fill: "#e8f5e9"

    check1: "Count Match" {class: check}
    check2: "Sample Queries" {class: check}
    check3: "Latency Check" {class: check}
    check4: "Recall Check" {class: check}
  }

  checks.check1 -> idx_b4
  checks.check2 -> idx_b4
  checks.check3 -> idx_b4
  checks.check4 -> idx_b4

  note4: "Ensure no quality regression" {
    style.font-size: 10
    style.fill: "#ffffff"
  }
}

# ============================================
# PHASE 5: Atomic Swap
# ============================================

phase5: Phase 5 - Atomic Swap {
  style.fill: "#c8e6c9"
  style.stroke: "#4caf50"

  p5_title: "Flip Pointer" {class: phase}

  idx_a5: "Index A\n(STANDBY)" {class: retired}
  idx_b5: "Index B\n(ACTIVE)" {class: new_active}

  swap: "Atomic\nPointer Swap" {class: process}
  queries5: "All Queries" {class: queries}

  swap -> idx_b5: "Activate"
  queries5 -> idx_b5: "Now serving"

  note5: "Single transaction - immediate cutover" {
    style.font-size: 10
    style.fill: "#ffffff"
  }
}

# ============================================
# PHASE 6: Cleanup
# ============================================

phase6: Phase 6 - Cleanup {
  style.fill: "#ffebee"
  style.stroke: "#ef5350"

  p6_title: "Post-Swap Cleanup" {class: phase}

  idx_a6: "Index A\n(DELETE)" {class: retired}
  idx_b6: "Index B\n(ACTIVE)" {class: new_active}

  cleanup: "Delete A after\n24h confidence period" {class: cleanup}
  queries6: "All Queries" {class: queries}

  queries6 -> idx_b6: "Serving"
  idx_a6 -> cleanup: "Rollback available"

  note6: "Keep A briefly for emergency rollback" {
    style.font-size: 10
    style.fill: "#ffffff"
  }
}

# ============================================
# FLOW CONNECTIONS
# ============================================

phase1 -> phase2: "Build continues"
phase2 -> phase3: "Build complete"
phase3 -> phase4: "Lag = 0"
phase4 -> phase5: "Validation passed"
phase5 -> phase6: "Swap complete"

# ============================================
# IMPLEMENTATION OPTIONS
# ============================================

impl_options: "Atomic Swap Implementation Options" {
  style.fill: "#fafafa"
  style.stroke: "#bdbdbd"

  opt1: "Index Alias\n(PostgreSQL VIEW)" {class: arrow_box}
  opt2: "Application Pointer\n(Config Table)" {class: arrow_box}
  opt3: "Partition Swap\n(ATTACH/DETACH)" {class: arrow_box}
}

phase5 -> impl_options: "How to swap?" {style.stroke-dash: 3}

# Scale Decision Tree
# Decision tree for choosing partition strategy based on tenant and vector counts

direction: down

classes: {
  start: {
    shape: circle
    style.fill: "#1565c0"
    style.font-color: "#ffffff"
    width: 60
    height: 60
  }
  decision: {
    shape: diamond
    style.fill: "#fff9c4"
    style.stroke: "#f9a825"
    style.stroke-width: 2
  }
  decision_vector: {
    shape: diamond
    style.fill: "#e1f5fe"
    style.stroke: "#0288d1"
    style.stroke-width: 2
  }
  strategy_global: {
    shape: rectangle
    style.fill: "#4caf50"
    style.font-color: "#ffffff"
    style.border-radius: 8
    style.bold: true
    style.stroke-width: 3
    style.stroke: "#2e7d32"
  }
  strategy_bucket: {
    shape: rectangle
    style.fill: "#ff9800"
    style.font-color: "#ffffff"
    style.border-radius: 8
    style.bold: true
    style.stroke-width: 3
    style.stroke: "#ef6c00"
  }
  strategy_twotier: {
    shape: rectangle
    style.fill: "#9c27b0"
    style.font-color: "#ffffff"
    style.border-radius: 8
    style.bold: true
    style.stroke-width: 3
    style.stroke: "#7b1fa2"
  }
  action: {
    shape: rectangle
    style.fill: "#e3f2fd"
    style.stroke: "#1976d2"
    style.border-radius: 4
  }
  warning: {
    shape: rectangle
    style.fill: "#ffebee"
    style.stroke: "#ef5350"
    style.border-radius: 4
  }
  threshold: {
    shape: text
    style.font-size: 12
    style.font-color: "#666666"
  }
  yes_label: {
    style.stroke: "#4caf50"
    style.stroke-width: 2
  }
  no_label: {
    style.stroke: "#f44336"
    style.stroke-width: 2
  }
}

title: "Partition Strategy Decision Tree" {
  style.font-size: 24
  style.bold: true
  style.font-color: "#1565c0"
  near: top-center
}

# ============================================
# START
# ============================================

start: "Start" {class: start}

# ============================================
# TENANT COUNT DECISIONS
# ============================================

tenant_check_50k: "Tenant Count\n< 50K?" {class: decision}

start -> tenant_check_50k: ""

# Branch 1: < 50K tenants
vector_check_1m: "Vectors/Index\n< 1M?" {class: decision_vector}

tenant_check_50k -> vector_check_1m: "Yes" {class: yes_label}

# < 50K tenants, < 1M vectors -> Global
global_strategy: "GlobalPartitionStrategy\n\nSingle HNSW + Metadata Filter\n\nSimplest operational model" {class: strategy_global}

vector_check_1m -> global_strategy: "Yes" {class: yes_label}

# < 50K tenants, >= 1M vectors
vector_check_10m_small: "Vectors/Index\n< 10M?" {class: decision_vector}

vector_check_1m -> vector_check_10m_small: "No" {class: no_label}

# < 50K tenants, 1M-10M vectors -> Global with monitoring
global_with_monitor: "GlobalPartitionStrategy\n\n+ Monitor latency\n+ Consider buckets if p95 > 200ms" {class: strategy_global}

vector_check_10m_small -> global_with_monitor: "Yes" {class: yes_label}

# < 50K tenants, >= 10M vectors -> Bucketed
bucket_strategy_small: "BucketedPartitionStrategy\n\n256 buckets\n(required for scale)" {class: strategy_bucket}

vector_check_10m_small -> bucket_strategy_small: "No" {class: no_label}

# ============================================
# MEDIUM SCALE: 50K - 5M TENANTS
# ============================================

tenant_check_5m: "Tenant Count\n< 5M?" {class: decision}

tenant_check_50k -> tenant_check_5m: "No" {class: no_label}

# 50K - 5M tenants
bucket_size_check: "Individual Bucket\n> 1M vectors?" {class: decision_vector}

tenant_check_5m -> bucket_size_check: "Yes" {class: yes_label}

# 50K - 5M tenants, buckets < 1M -> 256 buckets
bucket_256: "BucketedPartitionStrategy\n\n256 buckets\nhash(tenant_id) % 256" {class: strategy_bucket}

bucket_size_check -> bucket_256: "No" {class: yes_label}

# 50K - 5M tenants, buckets > 1M -> 1024 buckets
bucket_1024: "BucketedPartitionStrategy\n\n1024 buckets\nIncrease bucket count" {class: strategy_bucket}

bucket_size_check -> bucket_1024: "Yes" {class: no_label}

# ============================================
# LARGE SCALE: 5M+ TENANTS
# ============================================

time_sensitive_check: "Time-sensitive\nrecent data access?" {class: decision}

tenant_check_5m -> time_sensitive_check: "No (5M+)" {class: no_label}

# 5M+ tenants, time-sensitive -> Two-tier
twotier_strategy: "TwoTierPartitionStrategy\n\nHot: Recent < 30d (in-memory/brute)\nCold: Bucketed HNSW (1024)" {class: strategy_twotier}

time_sensitive_check -> twotier_strategy: "Yes" {class: yes_label}

# 5M+ tenants, not time-sensitive -> Large bucketed
bucket_large: "BucketedPartitionStrategy\n\n1024+ buckets\n+ Sharding across nodes" {class: strategy_bucket}

time_sensitive_check -> bucket_large: "No" {class: no_label}

# ============================================
# ADDITIONAL TRIGGERS (RIGHT SIDE)
# ============================================

triggers: "Rebuild/Migration Triggers" {
  style.fill: "#fafafa"
  style.stroke: "#bdbdbd"

  latency_trigger: "p95 > 200ms\nconsistently?" {class: warning}
  tombstone_trigger: "Tombstones > 10%\nof index?" {class: warning}
  build_trigger: "Index build time\n> 30 minutes?" {class: warning}

  action_rebuild: "Schedule Index Rebuild" {class: action}
  action_migrate: "Consider Migration\nto Higher Scale Strategy" {class: action}

  latency_trigger -> action_migrate
  tombstone_trigger -> action_rebuild
  build_trigger -> action_migrate
}

# ============================================
# LEGEND
# ============================================

legend: "Legend" {
  style.fill: "#f5f5f5"
  style.stroke: "#bdbdbd"

  l1: "Tenant Decision" {class: decision}
  l2: "Vector Decision" {class: decision_vector}
  l3: "Global Strategy" {class: strategy_global}
  l4: "Bucketed Strategy" {class: strategy_bucket}
  l5: "Two-Tier Strategy" {class: strategy_twotier}
}

# ============================================
# THRESHOLDS SUMMARY
# ============================================

thresholds: "Key Thresholds: Tenants <50K=Global, 50K-5M=Bucketed, 5M+=Two-Tier. Vectors <1M=Single, 1M-10M=Consider buckets, 10M+=Required. p95>200ms=Tune/migrate. Tombstones>10%=Rebuild." {
  near: bottom-center
  style.fill: "#ffffff"
  style.stroke: "#e0e0e0"
  style.font-size: 11
}

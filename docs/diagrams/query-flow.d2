# Query Flow Diagram
# Shows the complete query lifecycle from request to response

direction: down

classes: {
  input: {
    shape: rectangle
    style.fill: "#1565c0"
    style.font-color: "#ffffff"
    style.border-radius: 8
  }
  process: {
    shape: rectangle
    style.fill: "#438dd5"
    style.font-color: "#ffffff"
    style.border-radius: 4
  }
  decision: {
    shape: diamond
    style.fill: "#fff9c4"
    style.stroke: "#f9a825"
  }
  strategy: {
    shape: hexagon
    style.fill: "#e8f5e9"
    style.stroke: "#43a047"
  }
  index: {
    shape: cylinder
    style.fill: "#85bbf0"
    style.font-color: "#000000"
  }
  merge: {
    shape: parallelogram
    style.fill: "#fff3e0"
    style.stroke: "#ef6c00"
  }
  output: {
    shape: rectangle
    style.fill: "#4caf50"
    style.font-color: "#ffffff"
    style.border-radius: 8
  }
  annotation: {
    shape: text
    style.font-size: 11
    style.font-color: "#666666"
  }
}

# ============================================
# QUERY FLOW
# ============================================

title: "Vector Query Flow" {
  style.font-size: 24
  style.bold: true
  style.font-color: "#1565c0"
  near: top-center
}

# Step 1: Query Input
query_input: "Incoming Query\n(query_text, tenant_id, filters)" {class: input}

# Step 2: Embed Query
embed: "Embed Query Text\ntext -> vector(1536)" {class: process}

query_input -> embed: "1"

# Step 3: Strategy Selection
strategy_select: "Partition\nStrategy?" {class: decision}

embed -> strategy_select: "2"

# Strategy branches
global_strategy: "GlobalPartitionStrategy\nSingle Index" {class: strategy}
bucket_strategy: "BucketedPartitionStrategy\nhash(tenant_id) % N" {class: strategy}
twotier_strategy: "TwoTierPartitionStrategy\nHot + Cold" {class: strategy}

strategy_select -> global_strategy: "< 50K tenants"
strategy_select -> bucket_strategy: "50K - 5M tenants"
strategy_select -> twotier_strategy: "5M+ tenants"

# Step 4: Determine Partitions
partitions: "Determine Target Partitions" {class: process}

global_strategy -> partitions: "3a"
bucket_strategy -> partitions: "3b"
twotier_strategy -> partitions: "3c"

# Step 5: Search Indices
search_box: "Search Target Indices" {
  style.fill: "#e3f2fd"
  style.stroke: "#1976d2"
  style.stroke-width: 2

  idx1: "Index 1" {class: index}
  idx2: "Index 2" {class: index}
  idx3: "Index N" {class: index}
}

partitions -> search_box: "4. ANN Search with ef_search"

# Step 6: Apply Filters
filter: "Apply Metadata Filters\ntenant_id, source_list, category" {class: process}

search_box -> filter: "5. Candidates"

# Step 7: Merge Results
merge_results: "Merge & Deduplicate\nResults from all partitions" {class: merge}

filter -> merge_results: "6. Filtered candidates"

# Step 8: Rerank (optional)
rerank: "Rerank?\n(optional)" {class: decision}

merge_results -> rerank: "7"

# Step 9: Return Top K
topk: "Return Top K\n(k = limit param)" {class: process}

rerank -> topk: "8. Reranked/merged"

# Step 10: Response
response: "Response\n{entity_id, distance, metadata}" {class: output}

topk -> response: "9"

# ============================================
# ANNOTATIONS (as separate elements)
# ============================================

annotations: "Performance Notes" {
  style.fill: "#f5f5f5"
  style.stroke: "#bdbdbd"

  perf_note: "Performance Targets:\np95 latency < 100ms\nRecall@20 > 95%" {
    style.fill: "#ffffff"
    style.stroke: "#e0e0e0"
    style.font-size: 10
  }

  ef_note: "ef_search tuning:\nLow latency: 40-60\nBalanced: 100\nHigh recall: 200-300" {
    style.fill: "#ffffff"
    style.stroke: "#e0e0e0"
    style.font-size: 10
  }
}

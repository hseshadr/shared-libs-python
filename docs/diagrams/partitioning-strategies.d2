# Partitioning Strategies Comparison
# Visual comparison of the 3 partitioning strategies for HNSW vector indices

direction: right

classes: {
  strategy: {
    shape: rectangle
    style.fill: "#1168bd"
    style.font-color: "#ffffff"
    style.border-radius: 8
    style.font-size: 18
    style.bold: true
  }
  index: {
    shape: cylinder
    style.fill: "#438dd5"
    style.font-color: "#ffffff"
  }
  bucket: {
    shape: cylinder
    style.fill: "#85bbf0"
    style.font-color: "#000000"
  }
  hot: {
    shape: cylinder
    style.fill: "#ff7043"
    style.font-color: "#ffffff"
  }
  cold: {
    shape: cylinder
    style.fill: "#5c6bc0"
    style.font-color: "#ffffff"
  }
  query: {
    shape: rectangle
    style.fill: "#fff9c4"
    style.stroke: "#f9a825"
    style.border-radius: 4
  }
  filter: {
    shape: hexagon
    style.fill: "#e8f5e9"
    style.stroke: "#43a047"
  }
  router: {
    shape: diamond
    style.fill: "#fff3e0"
    style.stroke: "#ef6c00"
  }
  result: {
    shape: rectangle
    style.fill: "#c8e6c9"
    style.stroke: "#388e3c"
    style.border-radius: 4
  }
  label: {
    shape: text
    style.font-size: 14
    style.font-color: "#666666"
  }
  scale: {
    shape: rectangle
    style.fill: "#f3e5f5"
    style.stroke: "#8e24aa"
    style.border-radius: 4
    style.font-size: 12
  }
}

# ============================================
# STRATEGY 1: Global Partition Strategy
# ============================================

global: GlobalPartitionStrategy {
  style.fill: "#e3f2fd"
  style.stroke: "#1976d2"
  style.stroke-width: 2

  title: "Single Global HNSW + Metadata Filter" {class: strategy}
  scale_label: "< 50K Tenants" {class: scale}

  query1: "Query" {class: query}

  index1: "Global HNSW Index\n(All Tenants)" {class: index}

  filter1: "Post-Filter\ntenant_id = X\nsource_list IN (...)" {class: filter}

  result1: "Top K Results" {class: result}

  query1 -> index1: "1. ANN Search"
  index1 -> filter1: "2. Candidates"
  filter1 -> result1: "3. Filtered"

  # Data flow annotation
  note1: |md
    **Pros:**
    - Simplest model
    - Best index reuse
    - Single index to maintain

    **Cons:**
    - Post-filter can reduce recall
    - All tenants share overhead
  | {
    style.fill: "#ffffff"
    style.stroke: "#e0e0e0"
    style.font-size: 11
  }
}

# ============================================
# STRATEGY 2: Bucketed Partition Strategy
# ============================================

bucketed: BucketedPartitionStrategy {
  style.fill: "#fff3e0"
  style.stroke: "#ef6c00"
  style.stroke-width: 2

  title: "Bucketed HNSW by Tenant Hash" {class: strategy}
  scale_label: "50K - 5M Tenants" {class: scale}

  query2: "Query" {class: query}

  router2: "hash(tenant_id)\n% N" {class: router}

  buckets: Buckets {
    style.fill: "#fffde7"

    b0: "Bucket 0\nHNSW" {class: bucket}
    b1: "Bucket 1\nHNSW" {class: bucket}
    b2: "..." {class: bucket}
    bn: "Bucket N\nHNSW" {class: bucket}
  }

  filter2: "tenant_id\nfilter" {class: filter}

  result2: "Top K Results" {class: result}

  query2 -> router2: "1. Compute bucket"
  router2 -> buckets.b0: "2a. Route" {style.stroke-dash: 3}
  router2 -> buckets.b1: "2b. Route" {style.stroke-dash: 3}
  router2 -> buckets.bn: "2c. Route" {style.stroke-dash: 3}
  buckets.b0 -> filter2: "3. Search" {style.stroke-dash: 3}
  buckets.b1 -> filter2: "3. Search" {style.stroke-dash: 3}
  buckets.bn -> filter2: "3. Search" {style.stroke-dash: 3}
  filter2 -> result2: "4. Filtered"

  note2: |md
    **Pros:**
    - Smaller indices = faster
    - Predictable memory growth
    - Better isolation

    **Cons:**
    - N indices to manage
    - Rebalancing complexity
  | {
    style.fill: "#ffffff"
    style.stroke: "#e0e0e0"
    style.font-size: 11
  }
}

# ============================================
# STRATEGY 3: Two-Tier Partition Strategy
# ============================================

twotier: TwoTierPartitionStrategy {
  style.fill: "#f3e5f5"
  style.stroke: "#8e24aa"
  style.stroke-width: 2

  title: "Hot Cache + Global Cold Index" {class: strategy}
  scale_label: "5M+ Tenants / Time-Sensitive" {class: scale}

  query3: "Query" {class: query}

  tiers: Tiers {
    style.fill: "#fce4ec"

    hot: "Hot Tier\n(Recent < 30d)" {class: hot}
    cold: "Cold Tier\n(Historical)" {class: cold}
  }

  merge: "Merge\nResults" {class: router}

  rerank: "Rerank\n(optional)" {class: filter}

  result3: "Top K Results" {class: result}

  query3 -> tiers.hot: "1a. Search hot"
  query3 -> tiers.cold: "1b. Search cold"
  tiers.hot -> merge: "2a. Hot results"
  tiers.cold -> merge: "2b. Cold results"
  merge -> rerank: "3. Combined"
  rerank -> result3: "4. Final"

  note3: |md
    **Pros:**
    - Fast for recent data
    - Reduces cold index load
    - Better cache locality

    **Cons:**
    - Dual-write complexity
    - Cache invalidation needed
  | {
    style.fill: "#ffffff"
    style.stroke: "#e0e0e0"
    style.font-size: 11
  }
}

# Layout connections (invisible, for positioning)
global -> bucketed: "" {style.opacity: 0}
bucketed -> twotier: "" {style.opacity: 0}
